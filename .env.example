# ============================================================
# Razkindo ERP - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct DB connection (Prisma) - Use Supabase pooler for connection pooling
DATABASE_URL=postgresql://postgres.project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30
DIRECT_URL=postgresql://postgres.project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connect_timeout=30

# --- Auth (WAJIB di production!) ---
# Generate dengan: openssl rand -hex 32
AUTH_SECRET=GANTI_DENGAN_STRING_RANDOM_32_KARAKTER

# --- Moota (Optional - untuk bank mutation sync) ---
MOOTA_API_URL=https://app.moota.co/api/v2
MOOTA_PERSONAL_TOKEN=your-moota-token

# --- App Settings ---
NEXT_PUBLIC_APP_NAME=Razkindo ERP
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Server Settings ---
LOG_LEVEL=info
NODE_ENV=production

# --- STB Mode (Set 'true' untuk Set-Top Box dengan RAM terbatas) ---
STB_MODE=true

# --- Node Memory (untuk STB 2GB RAM) ---
NODE_OPTIONS=--max-old-space-size=384
